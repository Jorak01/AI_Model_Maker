# ============================================
# AI_Model Project .gitignore
# ============================================

# --- Sensitive / Private Config Files ---
# These are the main config files (contain secrets, never committed).
# Backup templates in config/ can be used to recreate them if needed.
config.yaml
docker-compose.yml
.env
pytest.ini

# --- IDE / Editor ---
.vscode/
*.code-workspace
*.swp
*.swo
*~

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# --- Virtual Environments ---
venv/
.venv/
env/

# --- Testing / Coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Data / Outputs / Logs ---
data/
logs/
outputs/
exports/
checkpoints/

# --- Model Binaries ---
*.pt
*.pth
*.pkl
*.onnx
*.tar.gz
*.bin
*.safetensors

# --- Docker ---
*.log

# --- OS Files ---
Thumbs.db
.DS_Store
desktop.ini
/docker-compose.yml
/__pycache__
/.vscode
/config.yaml
/pytest.ini
/plugins/__pycache__
/generated_images
/models/__pycache__