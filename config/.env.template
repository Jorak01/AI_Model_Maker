# ============================================
# AI Model Suite — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# The .env file is loaded by Docker Compose and can be read
# by the application via os.environ / config_manager.
# Environment variables OVERRIDE values in config.yaml.
#
# IMPORTANT: .env is in .gitignore — never commit secrets!
# ============================================


# ─── API Keys (External Providers) ─────────────────────────────────
# Required only if you want to use external LLM providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
CUSTOM_API_KEY=


# ─── API Base URLs (External Providers) ────────────────────────────
# Change these only if using a proxy, self-hosted instance, or
# alternative endpoint (e.g., Azure OpenAI, local vLLM, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OLLAMA_BASE_URL=http://localhost:11434
CUSTOM_BASE_URL=


# ─── Default Models per Provider ───────────────────────────────────
# Set to the model you want each provider to use by default.
OPENAI_DEFAULT_MODEL=gpt-4.1
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
GOOGLE_DEFAULT_MODEL=gemini-2.5-flash
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
OLLAMA_DEFAULT_MODEL=llama3.3
CUSTOM_DEFAULT_MODEL=


# ─── Public Data Source URLs ───────────────────────────────────────
# Used by auto-trainer, web_collector, RAG, and agent for fetching
# public domain data.  Change only if self-hosting or using a mirror.
WIKIPEDIA_API_URL=https://en.wikipedia.org/w/api.php
DUCKDUCKGO_URL=https://html.duckduckgo.com/html/
STACKEXCHANGE_API_URL=https://api.stackexchange.com/2.3
DANBOORU_API_URL=https://danbooru.donmai.us
HUGGINGFACE_API_URL=https://huggingface.co/api


# ─── Device / Hardware ─────────────────────────────────────────────
# Set to "cpu" or "cuda:0", "cuda:1", etc.
# AI_MODEL_DEVICE=cuda:0
# AI_MODEL_DEVICE=cpu


# ─── Model & Training Overrides ───────────────────────────────────
# These override the corresponding config.yaml values.
# AI_MODEL_BASE=gpt2
# AI_MODEL_PIPELINE=finetune
# AI_MODEL_LR=0.0001
# AI_MODEL_EPOCHS=10
# AI_MODEL_BATCH=32
# AI_MODEL_MAX_LENGTH=256
# AI_MODEL_TEMPERATURE=0.8


# ─── Server Ports ──────────────────────────────────────────────────
# Ports for each service. Change to avoid conflicts.
AI_MODEL_API_HOST=0.0.0.0
AI_MODEL_API_PORT=8000
AI_MODEL_COMPAT_PORT=8001
AI_MODEL_WEBUI_PORT=7860
AI_MODEL_DASHBOARD_PORT=5555


# ─── Docker-Specific ──────────────────────────────────────────────
# These are only used inside Docker Compose containers.
# COMPOSE_PROJECT_NAME=ai-model-suite
